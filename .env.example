# tg发送消息的反代地址
TELEGRAM_API_URL=https://xxx.com

# 存储驱动: local / webdav / telegram
STORAGE_DRIVER=local

# WebDAV 存储配置（当 STORAGE_DRIVER=webdav 时生效）
# 示例：Nextcloud WebDAV
# WEBDAV_BASE_URL=https://your-domain.com/remote.php/dav/files/username/bsimgbed
# WEBDAV_USERNAME=your_username
# WEBDAV_PASSWORD=your_password

# Telegram 储存配置（当 STORAGE_DRIVER=telegram 时生效）
# 可以复用你通知用的 Bot，也可以单独新建一个 Bot
# TG_STORAGE_TOKEN=123456:abcdefg_your_bot_token
# TG_STORAGE_CHAT_ID=123456789